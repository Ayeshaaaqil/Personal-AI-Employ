{
  "version": 2,
  "builds": [
    {
      "src": "vercel_app.py",
      "use": "@vercel/python@3.1.0"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "vercel_app.py"
    }
  ],
  "build": {
    "env": {
      "PYTHON_VERSION": "3.10"
    },
    "command": "pip install -r requirements.txt"
  },
  "env": {
    "PYTHON_VERSION": "3.10"
  }
}

# ============================================
# HUGGING FACE CONFIGURATION (Platinum Tier)
# ============================================

# Get your token from: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=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

# Model to use (default: Llama 3 70B Instruct)
HUGGINGFACE_MODEL=meta-llama/Meta-Llama-3-70B-Instruct

# Hugging Face API URL (optional)

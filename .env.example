# ============================================
# ODOO ERP CONFIGURATION (Gold Tier)
# ============================================

# Odoo URL (local or cloud)
ODOO_URL=http://localhost:8069

# Odoo database name
ODOO_DATABASE=odoo

# Odoo username
ODOO_USERNAME=admin

# Odoo password
ODOO_PASSWORD=admin

# Odoo API key (if using cloud)
ODOO_API_KEY=your_odoo_api_key

# ============================================
# WEB DASHBOARD CONFIGURATION (Platinum Tier)
# ============================================

# Web dashboard port
WEB_DASHBOARD_PORT=7860

# Web dashboard host
WEB_DASHBOARD_HOST=0.0.0.0

# Enable WebSocket for real-time updates
ENABLE_WEBSOCKET=true

# ============================================
# API CONFIGURATION (Platinum Tier)
# ============================================

# API host
API_HOST=0.0.0.0

# API port
API_PORT=8000

# API key for authentication
API_KEY=your_secret_api_key_change_this

# ============================================
# VAULT CONFIGURATION
# ============================================

# Path to Obsidian vault
VAULT_PATH=AI_Employee_Vault

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log file path
LOG_FILE_PATH=AI_Employee_Vault/Logs/orchestrator.log

# ============================================
# SECURITY CONFIGURATION
# ============================================

# Enable dry run mode (no real actions)
DRY_RUN=false

# Development mode
DEV_MODE=false

# Rate limiting (requests per minute)
RATE_LIMIT=60

# Maximum actions per hour
MAX_ACTIONS_PER_HOUR=100

# ============================================
# NOTIFICATION CONFIGURATION
# ============================================

# Email for notifications
NOTIFICATION_EMAIL=muhammadaaqil565@gmail.com

# WhatsApp number for urgent alerts
NOTIFICATION_WHATSAPP=03178916907

# ============================================
# SCHEDULING CONFIGURATION
# ============================================

# CEO Briefing schedule (cron format)
CEO_BRIEFING_SCHEDULE=0 8 * * 1  # Every Monday at 8 AM

# Audit log rotation (days)
AUDIT_LOG_ROTATION_DAYS=90

# ============================================
# DOCKER CONFIGURATION (Optional)
# ============================================

# Enable Docker deployment
ENABLE_DOCKER=false

# Docker Compose project name
DOCKER_PROJECT_NAME=ai-employee

# ============================================
# MISC CONFIGURATION
# ============================================

# Timezone
TIMEZONE=UTC

# Date format
DATE_FORMAT=%Y-%m-%d

# Currency symbol
CURRENCY_SYMBOL=$
